{
  "name": "pokemon-home-viewer",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "data": "node scripts/build-data.mjs",
    "fetch-learnsets": "node scripts/fetch-learnsets.mjs",
    "fetch-battle-usage-scvi": "node scripts/fetch-battle-usage-scvi.mjs",
    "fetch-battle-usage-swsh": "node scripts/fetch-battle-usage-swsh.mjs",
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "node scripts/build-data.mjs && vue-tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.32",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6"
  }
}
